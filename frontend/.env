# ===========================================
# AMIS Frontend - Environment Variables
# ===========================================

# ===========================================
# GO BACKEND API (PRIMARY - PRODUCTION)
# ===========================================
# Set the URL of your Go Backend API
# Example: https://api.yourdomain.com/api/v1
# Leave empty to use mock mode
VITE_API_URL=http://localhost:8080/api/v1

# ===========================================
# SUPABASE (DATABASE ONLY - BEHIND GO BACKEND)
# ===========================================
# Supabase is used as the database behind Go Backend
# Get these from your Supabase project settings
# Settings > API

VITE_SUPABASE_URL=https://qdbzrzcvsjnlqjbcphvn.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_VWRZ--uAmfj7y016SjiwGQ_K-gClcbB

# ===========================================
# API MODE
# ===========================================
# Set to 'true' to use mock/demo mode (ignores VITE_API_URL)
# Set to 'false' or leave empty to use Go Backend API
VITE_USE_MOCK=true

# ===========================================
# OPTIONAL SETTINGS
# ===========================================

# Application Name
VITE_APP_NAME=AMIS - Advanced Medical Information System

# Debug Mode (set to 'true' for development)
VITE_ENABLE_DEBUG=false

# ===========================================
# ARCHITECTURE NOTES
# ===========================================
# PRODUCTION ARCHITECTURE:
# React Frontend → Go Backend API → Supabase/Postgres
#
# Supabase Auth is NOT used directly by frontend.
# Authentication is handled by Go Backend via JWT tokens.
# Supabase is only used as the database layer.
