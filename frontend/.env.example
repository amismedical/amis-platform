# ===========================================
# MEDVERSE AN-NAHL / AMIS
# Environment Variables Configuration
# ===========================================

# ===========================================
# SUPABASE CONFIGURATION (REQUIRED)
# ===========================================
# Get these from your Supabase project settings
# Settings > API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# API MODE
# ===========================================
# false = Supabase (production) - DEFAULT
# true = Mock API (demo only)

VITE_USE_MOCK=false

# ===========================================
# OPTIONAL SETTINGS
# ===========================================

# Application Name
VITE_APP_NAME=Medverse An-Nahl (AMIS)

# Debug Mode (true for development)
VITE_ENABLE_DEBUG=false

# ===========================================
# IMPORTANT NOTES
# ===========================================
# 1. Run supabase-migration.sql in Supabase SQL Editor
# 2. Create storage buckets manually in Supabase Dashboard
# 3. Enable Realtime for required tables
# 4. Set up Email templates in Supabase Dashboard > Auth > Email Templates
# ===========================================